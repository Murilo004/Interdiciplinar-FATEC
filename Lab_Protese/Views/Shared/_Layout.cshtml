@{
  var tipo = Context.Session.GetString("TipoUsuario");
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/style.css" />
</head>
<body>

<header>
    <strong>Sistema MKMG</strong>
    <nav>
        <a asp-controller="Pedidos" asp-action="Pedidos">Pedidos</a>
        <a asp-controller="Servicos" asp-action="Servicos">Serviços</a>
        @if (tipo == "Dentista") 
        {
            <a asp-controller="Carrinho" asp-action="Carrinho">Carrinho</a>
        }
    </nav>
    <button class="avatar d-flex align-items-center justify-content-center border-0" data-bs-toggle="offcanvas" data-bs-target="#menuPessoa" aria-controls="menuPessoa">
        @Context.Session.GetString("NomeUsuario")?.Substring(0,1).ToUpper()
    </button>
    <div class="offcanvas offcanvas-end" tabindex="-1" id="menuPessoa">
        <div class="offcanvas-header border-bottom">
            <div>
                <h5 class="mb-0">
                    @Context.Session.GetString("NomeUsuario")
                </h5>
                <small class="text-muted">
                    @Context.Session.GetString("TipoUsuario")
                </small>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column">
            <a asp-controller="Auth" asp-action="Update" class="btn btn-outline-dark rounded-pill mb-3 py-2">Editar Perfil</a>
            <a asp-controller="Auth" asp-action="Logout" class="btn btn-danger rounded-pill py-2 mt-auto">Sair</a>
        </div>
    </div>
</header>

@RenderBody()

<div id="toast" class="toast"></div>
<script src="~/js/script.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>