@model Interdisciplinar.ViewModels.Auth.CadastroViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Cadastro - MKMG";
}

<div class="container py-4" style="max-width:450px;">
    <h2 class="text-center mb-4">Criar sua conta</h2>

    <form method="post" asp-controller="Auth" asp-action="Cadastro">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="mb-3">
            <label class="form-label">Nome Completo</label>
            <input asp-for="Nome" class="form-control" placeholder="Insira seu nome completo" />
            <span asp-validation-for="Nome" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Endereço</label>
            <input asp-for="Endereco" class="form-control" placeholder="Insira seu endereço" />
            <span asp-validation-for="Endereco" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Telefone</label>
            <input asp-for="Telefone" type="tel" class="form-control" placeholder="Insira seu telefone" />
            <span asp-validation-for="Telefone" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Email</label>
            <input asp-for="Email" type="email" class="form-control" placeholder="Insira seu e-mail" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Senha</label>
            @* BUG 13 CORRIGIDO: id="senha" para o JS encontrar o campo corretamente *@
            <input asp-for="Senha" id="senha" type="password" class="form-control" placeholder="Insira sua senha" />
            <span asp-validation-for="Senha" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Confirmar Senha</label>
            @* BUG 13 CORRIGIDO: campo vinculado ao ViewModel (validação server-side), não só JS *@
            <input asp-for="ConfirmarSenha" id="confirmarSenha" type="password" class="form-control" placeholder="Confirme sua senha" />
            <span asp-validation-for="ConfirmarSenha" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Função</label>
            <select asp-for="TipoUsuario" id="tipoUsuario" class="form-select">
                <option value="Dentista">Dentista</option>
                <option value="Protetico">Protético</option>
            </select>
            <span asp-validation-for="TipoUsuario" class="text-danger"></span>
            <br />
            <div class="mb-3" id="campoCro">
                <label class="form-label">CRO</label>
                <input asp-for="Cro" class="form-control" />
                <span asp-validation-for="Cro" class="text-danger"></span>
            </div>
            <div class="mb-3" id="campoCnpj">
                <label class="form-label">CNPJ</label>
                <input asp-for="Cnpj" class="form-control" />
                <span asp-validation-for="Cnpj" class="text-danger"></span>
            </div>
        </div>

        <div class="text-center mb-4">
            <button type="submit" class="btn btn-primary">Cadastrar</button>
        </div>
    </form>

    <p class="text-center mt-3">Já tem uma conta? <a class="btn btn-primary" asp-controller="Auth" asp-action="Login">Entrar</a></p>
</div>