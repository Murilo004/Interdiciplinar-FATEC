@model Interdisciplinar.ViewModels.Auth.CadastroViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Cadastro - MKMG";
}

<div class="container py-4" style="max-width:450px;">
    <h2 class="text-center mb-4">Criar sua conta</h2>

    <form method="post" asp-controller="Auth" asp-action="Cadastro" onsubmit="return validarSenhas()">
        <div class="mb-3">
            <label class="form-label">Nome Completo</label>
            <input asp-for="Nome" class="form-control" placeholder="Insira seu nome completo" required>
        </div>

        <div class="mb-3">
            <label class="form-label">Endereço</label>
            <input asp-for="Endereco" class="form-control" placeholder="Insira seu endereço" required>
        </div>

        <div class="mb-3">
            <label class="form-label">Telefone</label>
            <input asp-for="Telefone" type="tel" class="form-control" placeholder="Insira seu telefone" required>
        </div>

        <div class="mb-3">
            <label class="form-label">Email</label>
            <input asp-for="Email" type="email" class="form-control" placeholder="Insira seu e-mail" required>
        </div>

        <div class="mb-3">
            <label class="form-label">Senha</label>
            <input asp-for="Senha" type="password" class="form-control" placeholder="Insira sua senha" required>
        </div>

        <div class="mb-3">
            <label class="form-label">Confirmar Senha</label>
            <input id="confirmarSenha" type="password" asp-for="Senha" class="form-control" placeholder="Confirme sua senha" required>
            <div class="invalid-feedback">As senhas não coincidem.</div>
        </div>

        <div class="mb-3">
            <label class="form-label">Função</label>
            
            <select asp-for="TipoUsuario" id="tipoUsuario" class="form-select" required>
                <option value="Dentista">Dentista</option>
                <option value="Protetico">Protético</option>
            </select>
            <br />
            <div class="mb-3" id="campoCro">
                <label class="form-label">CRO</label>
                <input asp-for="Cro" class="form-control">
            </div>

            <div class="mb-3" id="campoCnpj">
                <label class="form-label">CNPJ</label>
                <input asp-for="Cnpj" class="form-control">
            </div>
        </div>

        <div class="text-center mb-4">
            <button type="submit" class="btn btn-primary">Cadastrar</button>
        </div>
    </form>

    <p class="text-center mt-3">Já tem uma conta? <a class="btn btn-primary"asp-controller="Auth" asp-action="Login">Entrar</a></p>
</div>