@model Servico

@{
    ViewData["Title"] = "Editar Serviço - MKMG";
}

<div class="container py-4" style="max-width:600px;">
    <h2 class="text-center mb-4">Editar Serviço</h2>

    <form method="post" asp-controller="Servicos" asp-action="Update">
        <input asp-for="Id" type="hidden" />

        <div class="mb-3">
            <label class="form-label">Nome</label>
            <input asp-for="Nome" class="form-control" required />
        </div>

        <div class="mb-3">
            <label class="form-label">Descrição</label>
            <input asp-for="Descricao" class="form-control" required />
        </div>

        <div class="mb-3">
            <label class="form-label">Preço</label>
            <input asp-for="Valor" type="number" step="0.01" class="form-control" required />
        </div>

        <div class="d-grid gap-2">
            <button type="submit" class="btn btn-primary rounded-pill">Atualizar Serviço</button>
            <a asp-controller="Servicos" asp-action="Servicos" class="btn btn-danger rounded-pill">Cancelar</a>
        </div>
    </form>
</div>